# ATWK — 環境變數範例（複製為 .env 後填入真實值）

# ============================================================
# 資料庫
# ============================================================
ATWK_DB_HOST=localhost
ATWK_DB_PORT=5432
ATWK_DB_NAME=db_atwk
ATWK_DB_USER=
ATWK_DB_PASSWORD=

# ============================================================
# LLM — 共用預設（若下方專屬設定留空，則 fallback 至此）
# ============================================================
ATWK_LLM_MODEL=gemini/gemini-2.0-flash
ATWK_LLM_API_KEY=

# 使用 LiteLLM Proxy 時填此項（否則留空）
ATWK_LLM_BASE_URL=

# ── Ingest LLM（後台文件處理，建議強推理模型）──────────────
# 留空時自動 fallback 至上方 ATWK_LLM_* 設定
ATWK_LLM_INGEST_MODEL=
ATWK_LLM_INGEST_API_KEY=
ATWK_LLM_INGEST_BASE_URL=

# ── Query LLM（前台問答，建議快速模型）─────────────────────
# 留空時自動 fallback 至上方 ATWK_LLM_* 設定
ATWK_LLM_QUERY_MODEL=
ATWK_LLM_QUERY_API_KEY=
ATWK_LLM_QUERY_BASE_URL=

# ============================================================
# 服務
# ============================================================
ATWK_PORT=8300
ATWK_SECRET_KEY=change-me-in-production

# ============================================================
# AgentPULSE（Layer 6 後填）
# ============================================================
APMS_BASE_URL=
APMS_AGENT_ID=

# ============================================================
# Wiki
# ============================================================
ATWK_WIKI_DIR=wiki
ATWK_RAW_DIR=raw
ATWK_INBOX_DIR=inbox
